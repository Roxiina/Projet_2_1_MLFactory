# ========================================
# 🏭 ML Factory - Configuration Example
# ========================================
# Copiez ce fichier vers .env et ajustez les valeurs selon vos besoins
# Usage: cp .env.example .env

# ========================================
# MinIO Configuration (S3-compatible Storage)
# ========================================
# Credentials pour le stockage des artefacts de modèles
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin

# Endpoint MinIO pour les services Docker (nom de service)
MLFLOW_S3_ENDPOINT_URL=http://minio:9000

# ========================================
# MLflow Configuration
# ========================================
# URI du serveur MLflow pour le tracking et le Model Registry
MLFLOW_TRACKING_URI=http://mlflow:5000

# Ignorer la vérification TLS pour MinIO en développement
MLFLOW_S3_IGNORE_TLS=true

# ========================================
# Application Configuration
# ========================================
# Nom du modèle dans le MLflow Model Registry
MODEL_NAME=iris_classifier

# Alias du modèle à utiliser en production
# Options: "Production", "Staging", "Champion", etc.
MODEL_ALIAS=Production

# ========================================
# Notes pour le développement local
# ========================================
# Pour exécuter les scripts Python en dehors de Docker (ex: src/train/train.py),
# créez un fichier .env.local avec les URLs localhost:
#
# MLFLOW_TRACKING_URI=http://localhost:5000
# MLFLOW_S3_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=minioadmin
# AWS_SECRET_ACCESS_KEY=minioadmin
# MLFLOW_S3_IGNORE_TLS=true
# MODEL_NAME=iris_classifier
# MODEL_ALIAS=Production
